{
  "name": "onlyfence",
  "version": "0.1.0",
  "description": "CLI tool giving AI trading agents controlled access to DeFi",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fence": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli/index.ts",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mysten/sui": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "bip39": "^3.1.0",
    "commander": "^12.0.0",
    "ed25519-hd-key": "^1.3.0",
    "smol-toml": "^1.3.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
