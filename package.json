{
  "name": "onlyfence",
  "version": "0.4.0",
  "description": "CLI tool giving AI trading agents controlled access to DeFi",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fence": "dist/cli/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/sync-version.js && node scripts/sync-changelog.js",
    "build": "tsc",
    "start": "tsx src/cli/index.ts",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/patch-bluefin-esm.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@7kprotocol/sdk-ts": "^4.0.0",
    "@alphafi/alphalend-sdk": "^1.1.27",
    "@bluefin-exchange/bluefin7k-aggregator-sdk": "5.1.6",
    "@bluefin-exchange/pro-sdk": "^1.13.0",
    "@cetusprotocol/aggregator-sdk": "^1.4.5",
    "@coral-xyz/anchor": "^0.29.0",
    "@flowx-finance/sdk": "^1.15.0",
    "@jup-ag/lend": "^0.1.9",
    "@jup-ag/lend-read": "^0.0.12",
    "@jup-ag/perpetuals-sdk": "^0.1.4",
    "@mysten/sui": "1.45.0",
    "@pythnetwork/pyth-sui-js": "^2.2.0",
    "@sentry/node": "^10.43.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "better-sqlite3": "^12.8.0",
    "bignumber.js": "^10.0.2",
    "bip39": "^3.1.0",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "commander": "^14.0.3",
    "ed25519-hd-key": "^1.3.0",
    "ink": "^6.8.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "react": "^19.2.4",
    "smol-toml": "^1.6.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings 0 --no-warn-ignored",
      "prettier --check"
    ]
  },
  "overrides": {
    "@bluefin-exchange/bluefin7k-aggregator-sdk": "$@bluefin-exchange/bluefin7k-aggregator-sdk"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
